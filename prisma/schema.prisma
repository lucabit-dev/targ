// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum WorkspaceMembershipRole {
  OWNER
  MEMBER
}

enum CaseSolveMode {
  QUICK_PATCH
  PROPER_FIX
  STRATEGIC_IMPROVEMENT
}

/// Optional user override; null means auto-detect at planning time.
enum CaseProblemLens {
  CODE
  UX_UI
  PRODUCT
  DOCTRINE
  MIXED
}

enum CaseWorkflowState {
  INTAKE
  ACTIVE
  RESOLVED
}

enum CaseAnalysisState {
  NOT_STARTED
  ANALYZING
  NEEDS_INPUT
  READY
  FAILED
}

enum CaseDraftState {
  NOT_STARTED
  READY
}

enum CaseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseConfidence {
  LIKELY
  PLAUSIBLE
  UNCLEAR
}

enum EvidenceKind {
  LOG
  SCREENSHOT
  ERROR_TEXT
  TERMINAL
  NOTE
  CODE
}

enum EvidenceSource {
  UPLOAD
  PASTE
  MANUAL_NOTE
}

enum EvidenceIngestStatus {
  PARSING
  READY
  NEEDS_REVIEW
  UNSUPPORTED
  FAILED
}

enum AnalysisRunStatus {
  ANALYZING
  NEEDS_INPUT
  READY
  FAILED
}

enum DiagnosisNextActionMode {
  FIX
  VERIFY
  REQUEST_INPUT
}

enum ClaimReferenceRelation {
  SUPPORTS
  WEAKENS
  UNCLEAR
}

enum ActionDraftType {
  FIX
  INVESTIGATION
}

enum ActionDraftStatus {
  DRAFTED
  SAVED
  SENT
  DISMISSED
}

/// Breakdown / bundle lifecycle on the case (pointers only; not a task tracker).
enum CaseBreakdownState {
  NOT_STARTED
  READY
}

enum CaseWorkBundleState {
  NOT_STARTED
  READY
}

/// Packaging state: generated snapshot vs user-dismissed in UI (no execution states).
enum WorkBundleStatus {
  GENERATED
  DISMISSED
}

/// Which third-party repo host a TargRepoLink points at. Only GitHub is wired
/// today; GitLab/Bitbucket can be added without changing surface shape.
enum RepoProvider {
  GITHUB
}

/// Visibility of a connected repo at sync time. `UNKNOWN` is the default until
/// the first metadata fetch succeeds; used by the UI to warn about permissions.
enum RepoVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
  UNKNOWN
}

/// Lifecycle of a TargRepoSnapshot (a pinned point-in-time index of a repo).
///
/// `PARTIAL` is used when a cap is hit (file count, symbol count, size) — the
/// snapshot is usable but incomplete, and the UI should surface that.
enum RepoSnapshotStatus {
  SYNCING
  READY
  PARTIAL
  FAILED
}

/// Coarse classification of a repo file, inferred from path + extension only.
/// Used by the resolver to bias matches away from tests / fixtures when the
/// evidence is clearly about production code.
enum RepoFileKind {
  CODE
  TEST
  CONFIG
  DOCS
  ASSET
  OTHER
}

/// Top-level symbol categories extracted during symbol indexing. Keep coarse
/// on purpose: resolver bias is by kind, not by fine-grained language specifics.
enum RepoSymbolKind {
  FUNCTION
  METHOD
  CLASS
  TYPE
  INTERFACE
  COMPONENT
  VARIABLE
  ENUM
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  passwordHash       String
  name               String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  memberships        WorkspaceMembership[]
  createdCases       TargCase[]            @relation("CasesCreatedByUser")
  analysisRuns       TargAnalysisRun[]     @relation("AnalysisRunsCreatedByUser")
  githubAccount      TargGithubAccount?
  connectedRepoLinks TargRepoLink[]        @relation("RepoLinksConnectedByUser")
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  personalForUserId    String?               @unique
  playbookConfig       Json?
  playbookConfiguredAt DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          WorkspaceMembership[]
  cases                TargCase[]
  repoLinks            TargRepoLink[]
}

model WorkspaceMembership {
  id          String                  @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMembershipRole @default(OWNER)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model TargCase {
  id                   String                  @id @default(cuid())
  workspaceId          String
  title                String
  createdByUserId      String
  workflowState        CaseWorkflowState
  analysisState        CaseAnalysisState
  draftState           CaseDraftState
  breakdownState       CaseBreakdownState      @default(NOT_STARTED)
  workBundleState      CaseWorkBundleState     @default(NOT_STARTED)
  userProblemStatement String
  /// Optional: shapes bundle depth and fix vs investigate bias.
  solveMode            CaseSolveMode?
  /// Optional override for classification; null = infer from text + evidence.
  problemLens          CaseProblemLens?
  severity             CaseSeverity?
  confidence           CaseConfidence?
  latestDiagnosisId    String?
  latestDraftId        String?
  latestBreakdownId    String?
  latestWorkBundleId   String?
  evidenceVersion      Int                     @default(1)
  /// Optional FK: the repo this case is scoped to. Null until the workspace
  /// has a repo linked or the user picks one for this case.
  repoLinkId           String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  resolvedAt           DateTime?
  workspace            Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser        User                    @relation("CasesCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)
  repoLink             TargRepoLink?           @relation(fields: [repoLinkId], references: [id], onDelete: SetNull)
  evidence             TargEvidence[]
  analysisRuns         TargAnalysisRun[]
  diagnosisSnapshots   TargDiagnosisSnapshot[]
  actionDrafts         TargActionDraft[]
  breakdowns           TargBreakdown[]
  workBundles          TargWorkBundle[]
  handoffs             TargHandoff[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([latestBreakdownId])
  @@index([latestWorkBundleId])
  @@index([createdByUserId])
  @@index([repoLinkId])
}

model TargEvidence {
  id                  String               @id @default(cuid())
  caseId              String
  kind                EvidenceKind
  source              EvidenceSource
  ingestStatus        EvidenceIngestStatus @default(PARSING)
  originalName        String
  mimeType            String?
  rawStorageUrl       String?
  rawText             String?
  redactedText        String?
  extracted           Json?
  caseEvidenceVersion Int                  @default(1)
  createdAt           DateTime             @default(now())
  case                TargCase             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  claimReferences     TargClaimReference[]

  @@index([caseId, createdAt(sort: Desc)])
  @@index([ingestStatus])
}

model TargAnalysisRun {
  id                 String                  @id @default(cuid())
  caseId             String
  createdByUserId    String
  status             AnalysisRunStatus       @default(ANALYZING)
  questionCount      Int                     @default(0)
  pendingQuestion    String?
  pendingOptions     Json?
  answers            Json?
  caseMemory         Json?
  failureMessage     String?
  latestDiagnosisId  String?
  completedAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  case               TargCase                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdByUser      User                    @relation("AnalysisRunsCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)
  diagnosisSnapshots TargDiagnosisSnapshot[]

  @@index([caseId, createdAt(sort: Desc)])
  @@index([createdByUserId])
  @@index([status])
}

model TargDiagnosisSnapshot {
  id                  String                  @id @default(cuid())
  caseId              String
  analysisRunId       String
  caseEvidenceVersion Int
  status              String
  confidence          CaseConfidence
  /// User-facing problem framing (scope, restatement). Append-only with snapshot.
  problemBrief        Json?
  probableRootCause   String
  affectedArea        String
  summary             String
  trace               Json
  hypotheses          Json
  contradictions      Json
  missingEvidence     Json
  nextActionMode      DiagnosisNextActionMode
  nextActionText      String
  claimReferences     Json
  createdAt           DateTime                @default(now())
  case                TargCase                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  analysisRun         TargAnalysisRun         @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  claimReferenceRows  TargClaimReference[]
  actionDrafts        TargActionDraft[]
  breakdowns          TargBreakdown[]
  workBundles         TargWorkBundle[]

  @@index([caseId, createdAt(sort: Desc)])
  @@index([analysisRunId])
}

model TargClaimReference {
  id                  String                 @id @default(cuid())
  diagnosisSnapshotId String
  claimKey            String
  claimText           String
  relation            ClaimReferenceRelation
  sourceLabel         String?
  summary             String?
  excerptText         String?
  evidenceId          String?
  createdAt           DateTime               @default(now())
  diagnosisSnapshot   TargDiagnosisSnapshot  @relation(fields: [diagnosisSnapshotId], references: [id], onDelete: Cascade)
  evidence            TargEvidence?          @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([diagnosisSnapshotId, claimKey])
  @@index([evidenceId])
}

/// Structured decomposition for a single diagnosis revision (append-only).
/// JSON fields follow `src/lib/planning/bundle-types.ts` (Targ-native schema).
model TargBreakdown {
  id                    String                @id @default(cuid())
  caseId                String
  diagnosisSnapshotId   String
  caseEvidenceVersion   Int
  schemaVersion         Int                   @default(1)
  /// Problem taxonomy + facets (optional until classifier runs).
  problemClassification Json?
  /// Shared spine: observed signal, boundaries, evidence index, decision stub, etc.
  sharedSpine           Json
  /// Mode-specific extension blocks (functional, experience, …).
  modeExtensions        Json
  /// Ranked hypotheses with keys stable for bundle task linking.
  rankedHypotheses      Json
  /// Open questions / falsification criteria not yet closed.
  unknowns              Json
  /// Cross-artifact deps (e.g. hypothesis H2 depends on evidence E1).
  artifactDependencies  Json
  /// Anchors to TargEvidence ids + semantic roles for bundle tasks.
  evidenceAnchors       Json
  /// Snapshot of diagnosis confidence at generation time (lineage).
  inheritedConfidence   CaseConfidence?
  createdAt             DateTime              @default(now())
  case                  TargCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  diagnosisSnapshot     TargDiagnosisSnapshot @relation(fields: [diagnosisSnapshotId], references: [id], onDelete: Cascade)
  workBundles           TargWorkBundle[]

  @@index([caseId, createdAt(sort: Desc)])
  @@index([diagnosisSnapshotId])
}

/// Packaged work proposal from a breakdown (append-only; export/handoff, not execution).
model TargWorkBundle {
  id                  String                @id @default(cuid())
  caseId              String
  diagnosisSnapshotId String
  breakdownId         String
  schemaVersion       Int                   @default(1)
  label               String?
  /// Full bundle: task groups, tasks, carried unknowns, confidence summary, evidence links.
  payload             Json
  status              WorkBundleStatus      @default(GENERATED)
  createdAt           DateTime              @default(now())
  case                TargCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  diagnosisSnapshot   TargDiagnosisSnapshot @relation(fields: [diagnosisSnapshotId], references: [id], onDelete: Cascade)
  breakdown           TargBreakdown         @relation(fields: [breakdownId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@index([diagnosisSnapshotId])
  @@index([breakdownId])
}

model TargActionDraft {
  id                  String                @id @default(cuid())
  caseId              String
  diagnosisSnapshotId String
  type                ActionDraftType
  title               String
  summary             String
  whyNow              String
  urgency             String
  suggestedSteps      Json
  risksOrUnknowns     Json?
  linkedEvidenceIds   Json
  status              ActionDraftStatus     @default(DRAFTED)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  savedAt             DateTime?
  case                TargCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  diagnosisSnapshot   TargDiagnosisSnapshot @relation(fields: [diagnosisSnapshotId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@index([diagnosisSnapshotId])
  @@index([status])
}

/// A rendered Handoff Packet sent to an external receiver (Cursor, Claude Code,
/// Codex, GitHub, Linear, Markdown). Append-only; one row per button click.
///
/// Source of truth for the packet shape: docs/handoff-packet.md
enum HandoffTarget {
  CURSOR
  CLAUDE_CODE
  CODEX
  COPILOT_WS
  GITHUB_ISSUE
  LINEAR_ISSUE
  MARKDOWN
}

model TargHandoff {
  id              String        @id @default(cuid())
  caseId          String
  diagnosisId     String?
  workBundleId    String?
  target          HandoffTarget
  /// Rendered Markdown actually delivered to the target (post-truncation).
  packetMd        String
  /// Structured HandoffPacket object that produced `packetMd`; keep for replay.
  packetJson      Json
  /// URL / issue number / PR url returned by the target, when applicable.
  externalRef     String?
  /// Truncation steps that ran before rendering, for debugging packet size.
  truncationSteps Json?
  createdByUserId String
  createdAt       DateTime      @default(now())
  case            TargCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@index([target])
  @@index([createdByUserId])
}

/// Per-user OAuth tokens for an external repo host. One row per (user, provider)
/// today (effectively just GitHub). Tokens are stored encrypted at rest.
model TargGithubAccount {
  id              String    @id @default(cuid())
  userId          String    @unique
  /// GitHub's numeric user id (stable across logins; login can change).
  githubUserId    Int       @unique
  githubLogin     String
  avatarUrl       String?
  /// Encrypted access token (AES-256-GCM, key from APP_TOKEN_ENCRYPTION_KEY).
  accessTokenEnc  String
  /// Encrypted refresh token, if the OAuth app uses refresh tokens.
  refreshTokenEnc String?
  expiresAt       DateTime?
  scope           String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([githubLogin])
}

/// A workspace <-> external repo association. Source of truth for repo context
/// used by the Handoff Packet (paths, branches, commit SHAs).
model TargRepoLink {
  id                String             @id @default(cuid())
  workspaceId       String
  /// Which user's OAuth token authorised this link. If that user loses access
  /// we may need to prompt another member to re-auth.
  connectedByUserId String
  provider          RepoProvider       @default(GITHUB)
  /// Provider's numeric repo id. Stable across renames.
  githubRepoId      Int
  ownerLogin        String
  repoName          String
  defaultBranch     String
  remoteUrl         String
  visibility        RepoVisibility     @default(UNKNOWN)
  lastSyncedAt      DateTime?
  /// Pointer to the most recent READY/PARTIAL snapshot for fast lookup. Null
  /// until the first sync completes. Also null if the latest snapshot FAILED.
  latestSnapshotId  String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectedByUser   User               @relation("RepoLinksConnectedByUser", fields: [connectedByUserId], references: [id], onDelete: Cascade)
  cases             TargCase[]
  snapshots         TargRepoSnapshot[] @relation("RepoSnapshotsForLink")
  latestSnapshot    TargRepoSnapshot?  @relation("LatestSnapshotForLink", fields: [latestSnapshotId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, githubRepoId])
  @@index([workspaceId])
  @@index([connectedByUserId])
}

/// A pinned point-in-time index of a repository at a specific commit. One row
/// per (repoLinkId, commitSha). The file/symbol tables are partitioned by
/// snapshotId so old snapshots stay queryable until we decide to prune.
model TargRepoSnapshot {
  id             String             @id @default(cuid())
  repoLinkId     String
  /// The commit SHA this snapshot pins. 40-char hex for GitHub.
  commitSha      String
  /// Which branch we read the tree from (usually the repo's default branch).
  branch         String
  status         RepoSnapshotStatus @default(SYNCING)
  /// Reason a snapshot is PARTIAL or FAILED, surfaced to the UI.
  statusDetail   String?
  /// Wall clocks for the two sync phases (tree fetch, symbol extraction).
  treeSyncedAt   DateTime?
  symbolSyncedAt DateTime?
  /// Totals populated as each phase completes; used by the UI status chip.
  fileCount      Int                @default(0)
  symbolCount    Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  repoLink       TargRepoLink       @relation("RepoSnapshotsForLink", fields: [repoLinkId], references: [id], onDelete: Cascade)
  linkedAsLatest TargRepoLink?      @relation("LatestSnapshotForLink")
  files          TargRepoFile[]
  symbols        TargRepoSymbol[]

  @@unique([repoLinkId, commitSha])
  @@index([repoLinkId, createdAt(sort: Desc)])
  @@index([status])
}

/// One row per file in a snapshot's default-branch tree. `blobSha` is the
/// GitHub blob SHA so we can detect unchanged files across resyncs and skip
/// re-parsing them during symbol indexing.
model TargRepoFile {
  id         String           @id @default(cuid())
  snapshotId String
  path       String
  size       Int
  blobSha    String
  kind       RepoFileKind     @default(OTHER)
  /// Best-effort language label derived from extension (e.g. "typescript",
  /// "python", "markdown"). Null for binaries / unknown extensions.
  language   String?
  createdAt  DateTime         @default(now())
  snapshot   TargRepoSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  symbols    TargRepoSymbol[]

  @@unique([snapshotId, path])
  @@index([snapshotId, kind])
  @@index([snapshotId, language])
}

/// Top-level named symbol inside a TargRepoFile. Populated by the symbol
/// indexer during Phase 2.2e (TS/JS/TSX/JSX only in the first cut). Used by
/// the resolver to answer "evidence mentions `processPayment` — where is it?".
model TargRepoSymbol {
  id         String           @id @default(cuid())
  snapshotId String
  fileId     String
  name       String
  kind       RepoSymbolKind
  /// 1-based line number of the symbol declaration start.
  line       Int
  /// 1-based line number of the symbol declaration end (null if trivial).
  endLine    Int?
  /// Whether the symbol is exported from the module. Helps the resolver
  /// prefer public API surfaces over internal helpers.
  exported   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  snapshot   TargRepoSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  file       TargRepoFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([snapshotId, name])
  @@index([snapshotId, kind])
  @@index([fileId])
}
